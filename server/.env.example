# Environment variables for the proxy server
# Copy this file to .env and fill in your values

# TheMealDB base URL (v1)
MEALDB_API_BASE=https://www.themealdb.com/api/json/v1

# API key — use "1" for free/dev access; replace with your paid key in production
MEALDB_API_KEY=1

# Port for the Express server
PORT=3001
