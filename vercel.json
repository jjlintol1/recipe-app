{
  "version": 2,
  "installCommand": "npm install --prefix client && npm install --prefix api",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "api/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
